  IV)MERGE:
  *********
  IT IS USED TO PERFFOM]RM INSERT AND UPDATE(UPSERT);

SYNTAX:
_______


    MERGE INTO A
USING B
ON condition
WHEN MATCHED THEN UPDATE
WHEN NOT MATCHED THEN INSERT;


EXAMPLE:

CREATE OR REPLACE TABLE A
(
EID NUMBER,
ENAME VARCHAR,
SAL NUMBER
);

INSERT INTO A VALUES
(101,'ALLEN',2000),
(102,'SMITH',3000);

select * from A;

CREATE OR REPLACE TABLE B
(
EID NUMBER,
ENAME VARCHAR,
SAL NUMBER
);

INSERT INTO B VALUES
(101,'ALLEN',5000),
(103,'BLAKE',4000);

SELECT * FROM B;



MERGE INTO A
USING B
ON A.EID=B.EID
WHEN MATCHED THEN
UPDATE SET A.SAL = B.SAL
WHEN NOT MATCHED THEN
INSERT (A.EID,A.ENAME,A.SAL)
VALUES (B.EID,B.ENAME,B.SAL);



